#!/usr/bin/env fish

# pick-files — fuzzy-pick files in the current tmux pane's directory and inject
# their (cwd-relative) paths into whatever program is running in that pane, via
# `tmux send-keys`. Built for TUIs/REPLs with no file picker of their own —
# claude, aider, a python/psql REPL, an editor's :terminal, etc.
#
# Triggered from tmux: prefix + C-f (display-popup, see dot-tmux.conf).
# Linux-only. Content-aware preview (fzf-preview) + the shared tokyonight theme.

source $HOME/.dotfiles/fish/fzf-theme.fish

set -l pane_dir (tmux display-message -p '#{pane_current_path}')
set -l pane_id (tmux display-message -p '#{pane_id}')
cd "$pane_dir"; or exit

# --height=100% fills the tmux popup (overrides the theme's inline 60%).
set -l selected (
    fd --type f --hidden --exclude .git \
        | fzf --multi --height=100% --reverse --preview 'fzf-preview {}'
)
test -z "$selected"; and exit

# space-joined, with a trailing space so you can keep typing in the TUI
tmux send-keys -t "$pane_id" (string join ' ' -- $selected)' '
