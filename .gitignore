.aider*

# Generated/state files that should never be tracked (regenerated by the system)
# .desktop database caches
home/dot-local/share/applications/mimeinfo.cache
home/dot-local/share/applications/mimeapps.list
# systemd user "enable" symlinks (.target.wants AND .service.wants, e.g.
# niri.service.wants/) — generated by `systemctl enable`/`add-wants`, owned by
# the `services-enable` recipe, never tracked.
**/systemd/user/*.wants/
