.aider*

# Docs build output (just docs): zensical HTML site + pandoc/typst PDFs.
# The generated markdown blocks in docs/*.md ARE tracked — only binary
# artifacts are ignored.
site/
docs/pdf/
tools/cheatsheets/data.json

# Claude Code project/session state — not config (at any depth in the tree)
.claude/

# Generated/state files that should never be tracked (regenerated by the system)
# .desktop database caches
home/dot-local/share/applications/mimeinfo.cache
home/dot-local/share/applications/mimeapps.list
# App-auto-registered .desktop launchers (Claude Code URL handler, Chrome PWAs).
# Intentional shortcuts are tracked explicitly (hide-stubs, custom launchers, and
# the WebApp-* entries under hosts/xps/) — only these auto-generated ones are ignored.
home/dot-local/share/applications/claude-code-url-handler.desktop
home/dot-local/share/applications/chrome-*.desktop
# systemd user "enable" symlinks (.target.wants AND .service.wants, e.g.
# niri.service.wants/) — generated by `systemctl enable`/`add-wants`, owned by
# the `services-enable` recipe, never tracked.
**/systemd/user/*.wants/
