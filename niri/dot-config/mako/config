sort=-time
layer=overlay
text-color=#a9b1d6
border-color=#33ccff
background-color=#1a1b26
width=420
height=110
padding=8
border-size=2
border-radius=4
font=iMWritingDuo Nerd Font Propo
anchor=top-right
outer-margin=20
default-timeout=3000
max-icon-size=32
icons=1
ignore-timeout=1

[app-name=Spotify]
invisible=1

[mode=do-not-disturb]
invisible=true

[mode=do-not-disturb app-name=notify-send]
invisible=false

[urgency=low]
border-color=#45475a

[urgency=normal]
border-color=#45475a

[urgency=high]
border-color=#dd4444
text-color=#dddddd
default-timeout=0

[category=mpd]
default-timeout=2000
group-by=category

# Claude-hook touch prompts (from ~/.claude/hooks/yubikey-touch-*, app-name
# "YubiKey"): vivid gold + draining progress bar. The hooks clear it on command
# completion; default-timeout is a ~30s fallback.
[app-name=YubiKey]
border-color=#ffcc00
progress-color=over #3a3320
default-timeout=30000

[mode=do-not-disturb app-name=YubiKey]
invisible=false

# Detector toast (any OTHER app's touch, via yubikey-touch-notifier, app-name
# "YubiKey-detector"): dimmer muted-gold + thinner border so it's obviously the
# secondary, background one at a glance. Low urgency, no progress fill.
[app-name=YubiKey-detector]
border-color=#8a7a3a
border-size=1
default-timeout=30000

[mode=do-not-disturb app-name=YubiKey-detector]
invisible=false
