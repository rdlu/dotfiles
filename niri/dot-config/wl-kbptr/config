[general]
# 11 chars: 8 for bisect cells (row-major: 0..3 top, 4..7 bottom),
# then left/right/middle click.
#
#   keyboard    screen cells
#   a s d f       0 1 2 3   (top)
#   z x c v       4 5 6 7   (bottom)
#
#   j = left click
#   k = right click
#   l = middle click
home_row_keys=asdfzxcvjkl
modes=tile,bisect

[mode_tile]
label_font_family=DepartureMono Nerd Font
selectable_bg_color=#4338ca77
selectable_border_color=#6366f1ff

[mode_bisect]
label_font_family=RecMonoCasual Nerd Font Mono

[mode_floating]
label_font_family=Agave Nerd Font Mono
label_font_size=20 70% 150
label_color=#ffff
label_select_color=#fd0f
selectable_bg_color=#003a
selectable_border_color=#08ff
unselectable_bg_color=#000a
